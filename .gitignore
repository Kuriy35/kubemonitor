profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Reference: https://github.com/pyenv/pyenv#local-version
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a database, lock file can be sensitive.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally tracked in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally tracked in version control.
#pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parses local traces, let's exclude them
*.sage.py

